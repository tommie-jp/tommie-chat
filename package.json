{
  "name": "tommie-chat",
  "private": true,
  "version": "0.1.14",
  "description": "ブラウザで動く3D MMOチャットゲーム (Browser-based 3D MMO chat)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-tommie/tommie-chat.git"
  },
  "type": "module",
  "scripts": {
    "//ktx2": "basisu your-image.png -ktx2 -mipmap -q 255",
    "ktx2": "toktx --t2 --encode uastc --genmipmap pic1.ktx2 pic1.png",
    "start": "vite preview",
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babylonjs/core": "^9.1.0",
    "@babylonjs/gui": "^9.1.0",
    "@babylonjs/loaders": "^9.1.0",
    "@babylonjs/materials": "^9.1.0",
    "@heroiclabs/nakama-js": "^2.8.0"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^9.1.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "ws": "^8.20.0"
  }
}
