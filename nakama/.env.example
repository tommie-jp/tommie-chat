# nakama/.env.example
#
# このファイルは doDeploy.sh が参照する環境変数一覧のサンプルです。
# 実体 (.env) は git 管理外。初回デプロイ時に doDeploy.sh が自動生成します。
# 複数環境（prod + test 等）を同一 VPS で並行運用する場合は、
# 各環境ディレクトリで COMPOSE_PROJECT_NAME を必ず変えてください。
#
# --- 必須（自動生成される） --------------------------------------------------
# POSTGRES_PASSWORD    postgres の nakama ユーザーパスワード
# NAKAMA_SERVER_KEY    Nakama WebSocket 接続用の共有鍵
# NAKAMA_CONSOLE_USER  管理コンソールのユーザー名（既定 admin）
# NAKAMA_CONSOLE_PASS  管理コンソールのパスワード
# MINIO_ROOT_USER      MinIO ルートユーザー
# MINIO_ROOT_PASSWORD  MinIO ルートパスワード
#
# --- 公開ホスト名 -----------------------------------------------------------
# DEPLOY_HOSTNAME      nginx Origin/Referer 検査に使う公開ホスト名
#                      未指定時は hostname -f の結果を使用する
# DEPLOY_HOSTNAME=mmo.tommie.jp
#
# --- マルチ環境（本番 + ステージング併設時のみ） ----------------------------
# COMPOSE_PROJECT_NAME docker compose プロジェクト名
#                      未指定 or tommchat-prod → 本番扱い（PORT_OFFSET=0）
#                      それ以外 → プロジェクト名 hash からポート offset を自動決定
# COMPOSE_PROJECT_NAME=tommchat-test
#
# PORT_OFFSET          0〜9 のポートオフセット
#                      各公開ポートは base + OFFSET*100 で割当てられる
#                      例) offset=1 → POSTGRES=5532, WEB=8181, NAKAMA_API=7450
#                      明示したい場合のみ指定する
# PORT_OFFSET=1
#
# --- ポート個別指定（PORT_OFFSET で足りない場合の上書き） -------------------
# POSTGRES_PORT=5432
# NAKAMA_PPROF_PORT=6060
# NAKAMA_GRPC_PORT=7349
# NAKAMA_API_PORT=7350
# NAKAMA_CONSOLE_PORT=7351
# WEB_PORT=8081
# PROMETHEUS_PORT=9090
# MINIO_S3_PORT=9000
# MINIO_CONSOLE_PORT=9001
#
# --- 任意（機能有効化時のみ） -----------------------------------------------
# GOOGLE_CLIENT_ID     Google OAuth2 Client ID（doc/53 参照）
# GOOGLE_CLIENT_SECRET Google OAuth2 Client Secret
# ADMIN_UIDS           管理者 UID（カンマ区切り）
