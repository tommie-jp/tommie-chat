{
    "name": "大文字小文字混在 (Pi, pI) は §4 違反で ER02 応答",
    "section": "§4, §4.1, §6.3",
    "required": true,
    "timeout_ms": 500,
    "_note": "v0.1: コマンドは大文字のみ受理。混在は ER02 (Lowercase command) で拒否。",
    "steps": [
        { "tx": "Pi" },
        { "rx_regex": "^ER02( .*)?$" },
        { "tx": "pI" },
        { "rx_regex": "^ER02( .*)?$" }
    ]
}
