@startuml 59-state-external-cpu
title 外部CPU UART プロトコル CPU 側 状態遷移図（例）

skinparam state {
    BackgroundColor<<boot>> #E8F5E9
    BackgroundColor<<idle>> #E3F2FD
    BackgroundColor<<play>> #FFF3E0
}

' === 状態定義 ===
' 受信＝サーバー → CPU、送信＝CPU → サーバー
' メッセージ書式は doc/reversi/61-UARTプロトコル仕様.md §メッセージ書式 参照
' 基本方針: 純粋リアクティブ（受信に反応して返すだけ）。
'           唯一の能動送信は BOOT 直後の "RE"（再送要求）。

state "C0: BOOT" as Boot <<boot>> {
    Boot : 電源投入直後
    Boot : 送信: "RE" （対局中リセットからの
    Boot :   復帰要求・任意）
    Boot : 初期化完了後は C1 へ
}

state "C1: IDLE" as Idle <<idle>> {
    Idle : 接続済み・対局なし or 終局後
    Idle : 何もしない（受信待ち）
    Idle : 終局種別（EB/EW/ED）は
    Idle :   必要なら内部変数に保持
}

state "C2: MY_TURN" as MyTurn <<play>> {
    MyTurn : CPU 手番
    MyTurn : 着手を計算
    MyTurn : 送信: "MOd?" / "PA"（パス）
    MyTurn :   / "EN"（投了）のいずれか
}

state "C3: WAIT_OPP" as WaitOpp <<play>> {
    WaitOpp : 相手手番
    WaitOpp : 何もしない（受信待ち）
}

' === 共通応答（副作用なし・自己遷移） ===
note as N1
  **共通応答**
  "PI" → "PO"（BOOT 以外の全状態で有効）
  "VE" → "VE<NN><名前>"（C1 以降で有効）
end note

' PI は BOOT を除く全状態で自己遷移（煩雑さ回避のため C1 のみ図示、C2/C3 も同様）
Idle    -left->  Idle    : P1: 受信 "PI"\n→ 送信 "PO"
Idle    -right-> Idle    : V1: 受信 "VE"\n→ 送信 "VE<NN><名前>"

' === 遷移 ===

' --- 起動 ---
[*] --> Boot : U0: 電源投入 / reset
Boot --> Idle : U1: "RE" 送信後

' --- 盤面同期（接続直後 / リセット復帰）---
Idle --> Idle : I1: 受信 "BO..."\n内部盤面を上書き\n(続く SB/SW を待つ)

' --- 対局開始 ---
Idle --> MyTurn : G1: 受信 "SB"\n(黒・先攻。直ちに着手計算)
Idle --> WaitOpp : G2: 受信 "SW"\n(白・後攻。相手の着手待ち)

' --- 対局ループ ---
MyTurn --> WaitOpp : M1: 送信 "MOd?"\n(通常着手)
MyTurn --> WaitOpp : M2: 送信 "PA"\n(合法手なし・パス)
MyTurn --> Idle   : M3: 送信 "EN"\n(自主投了 → IDLE へ戻る)

WaitOpp --> MyTurn : W1: 受信 "MOd?"\n(相手着手 → CPU 手番)
WaitOpp --> MyTurn : W2: 受信 "PA"\n(相手パス → CPU 手番)

' --- 終局 ---
MyTurn  --> Idle : E1: 受信 "EB"/"EW"/"ED"\n(着手前に終局通知 → IDLE へ)
WaitOpp --> Idle : E2: 受信 "EB"/"EW"/"ED"\n(→ IDLE へ)

@enduml
