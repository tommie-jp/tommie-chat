@startuml 61-scope
title 本書のスコープ（UART プロトコル仕様の適用範囲）

skinparam shadowing false
skinparam rankdir TB
skinparam ArrowColor black

skinparam rectangle {
    BackgroundColor<<server>> #F5F5F5
    BackgroundColor<<scope>> #FFCDD2
    BorderColor<<scope>> #C62828
    BorderThickness<<scope>> 2
    BackgroundColor<<phy>> #F5F5F5
    BackgroundColor<<cpu>> #F5F5F5
    BackgroundColor<<out>> #E0E0E0
}

rectangle "サーバー側（範囲外・実装自由）" as server <<server>> {
  rectangle "ネット通信 / ゲームロジック" as srv_game <<out>>
  rectangle "シリアル送受信" as srv_ser <<out>>
}

rectangle "本書が規定する範囲\nUART プロトコル" as scope <<scope>> {
  rectangle "アプリケーション層\n（メッセージ書式：SB/SW/MOd?/PS/BO.../EB/EW/ED/VE/PI）" as app
  rectangle "リンク層\n（ボーレート 8N1 / LF 送信・CR/LF/CRLF 受信）" as link
}

rectangle "物理層（範囲外・CPU 製作者の領分）" as phy <<phy>> {
  rectangle "USB-UART 変換器（CP210x / CH340 / FTDI 等)" as usb <<out>>
  rectangle "電圧レベル・ケーブル・コネクタ" as wire <<out>>
}

rectangle "CPU 側（範囲外・実装自由）" as cpu <<cpu>> {
  rectangle "自作 CPU\n（FPGA / MCU / ディスクリート / レッドストーン / etc.)" as mycpu <<out>>
}

server -down-> scope
scope -down-> phy
phy -down-> cpu

@enduml
