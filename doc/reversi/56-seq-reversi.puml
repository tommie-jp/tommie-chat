@startuml
title リバーシ対戦シーケンス図
skinparam sequenceMessageAlign center
skinparam maxMessageSize 200

actor "プレイヤーA\n(黒)" as A
actor "プレイヤーB\n(白)" as B
actor "観戦者C" as C
participant "Nakama\n(RPC)" as RPC
participant "MatchLoop\n(SignalHandler)" as ML
database "sync.Map\n(インメモリ)" as MEM

== 購読登録 ==

A -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidA] = true
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
note right : 購読開始時にゲーム一覧を即送信
deactivate ML

B -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidB] = true
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML

C -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidC] = true
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML

== ゲーム作成 ==

A -> RPC : othelloCreate\n{worldId: 0}
activate RPC
RPC -> MEM : OthelloGame 作成\nstatus=waiting, turn=1\nboardGX=504, boardGZ=504
RPC -> ML : MatchSignal\n"othelloBlocks"\n(外枠36ブロック)
activate ML
ML -> ML : チャンク保存\n+ AOI判定
ML -> A : OP_BLOCK_UPDATE(4)\n木枠ブロック (AOI内なら)
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC -> ML : MatchSignal\n"othelloBlocks"\n(初期盤面: 緑60+石4)
activate ML
ML -> A : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC -> ML : MatchSignal\n"othelloList"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML
RPC --> A : {gameId, status=waiting, board:[...]}
deactivate RPC

note over B : クライアントは onOthelloUpdate で\ntype:"list" を受信しロビーを更新

== 対戦参加 ==

B -> RPC : othelloJoin\n{gameId}
activate RPC
RPC -> MEM : white=B, status=playing
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"game", status=playing, turn=1}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"game", status=playing, turn=1}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"game", status=playing, turn=1}
deactivate ML
note right : othelloSignalBroadcast 内で\northelloBlockSignal も呼ばれるが\njoin時は盤面差分なし
RPC -> ML : MatchSignal\n"othelloList"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML
RPC --> B : {status=playing, turn=1, board:[...]}
deactivate RPC

== 着手（黒: プレイヤーA） ==

A -> RPC : othelloMove\n{gameId, row=2, col=3}
activate RPC
RPC -> MEM : 合法手判定 → 裏返し\nturn: 1→2
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"game", turn=2, lastMove=19}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"game", turn=2, lastMove=19}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"game", turn=2, lastMove=19}
deactivate ML
RPC -> ML : MatchSignal\n"othelloBlocks"\n(差分のみ)
activate ML
ML -> ML : チャンク保存\n+ AOI判定
ML -> A : OP_BLOCK_UPDATE(4)\n変化マスのブロック
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC --> A : {turn=2, flipped:[...]}
deactivate RPC

== 着手（白: プレイヤーB） ==

B -> RPC : othelloMove\n{gameId, row=2, col=2}
activate RPC
RPC -> MEM : 合法手判定 → 裏返し\nturn: 2→1
RPC -> ML : MatchSignal "othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)
ML -> B : OP_OTHELLO_UPDATE(18)
ML -> C : OP_OTHELLO_UPDATE(18)
deactivate ML
RPC -> ML : MatchSignal "othelloBlocks"
activate ML
ML -> A : OP_BLOCK_UPDATE(4)
ML -> B : OP_BLOCK_UPDATE(4)
ML -> C : OP_BLOCK_UPDATE(4)
deactivate ML
RPC --> B : {turn=1, flipped:[...]}
deactivate RPC

note over A, B : ...（交互に着手を繰り返す）...

== 終局（盤面埋まり or 2連続パス） ==

note over A, B
  othelloApplyMove 内で自動判定:
  - 相手に合法手なし → othelloPass
  - 2連続パス → othelloFinish
  - 全マス埋まり → othelloFinish
  winner = blackCount > whiteCount ? 1 : 2 (同数は 0)
end note

A -> RPC : othelloMove\n{gameId, row=7, col=7}
activate RPC
RPC -> MEM : 裏返し → 終局判定\nstatus=finished, winner=1
RPC -> ML : MatchSignal "othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> B : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> C : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
deactivate ML
RPC -> ML : MatchSignal "othelloBlocks"
activate ML
ML -> A : OP_BLOCK_UPDATE(4)
ML -> B : OP_BLOCK_UPDATE(4)
ML -> C : OP_BLOCK_UPDATE(4)
deactivate ML
RPC -> ML : MatchSignal "othelloList"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML
RPC --> A : {status=finished, winner=1, flipped:[...]}
deactivate RPC

== ブロッククリーンアップ（60秒後） ==

RPC -> RPC : goroutine\n60秒 sleep
activate RPC #LightGray
RPC -> MEM : othelloClearBlocks\n10x10 エリアを blockId=0
RPC -> MEM : othelloGames.Delete(gameId)
deactivate RPC

note over A, C : クライアントは次回 syncAOIChunks で\nハッシュ不一致を検出 → ブロック除去

== 投了 ==

B -> RPC : othelloResign\n{gameId}
activate RPC
RPC -> MEM : othelloResign(g, uid)\nstatus=finished, winner=1 (黒勝ち)
RPC -> ML : MatchSignal "othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> B : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> C : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
deactivate ML
RPC -> ML : MatchSignal "othelloList"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML
RPC -> RPC : goroutine\n60秒後 clearBlocks + Delete
RPC --> B : {status=finished, winner=1}
deactivate RPC

== キャンセル（waiting中のみ） ==

A -> RPC : othelloCancel\n{gameId}
activate RPC
RPC -> MEM : othelloClearBlocks\n(即時ブロック削除)
RPC -> MEM : othelloGames.Delete(gameId)
RPC -> ML : MatchSignal "othelloList"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> B : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
ML -> C : OP_OTHELLO_UPDATE(18)\n{type:"list", games:[...]}
deactivate ML
RPC --> A : {}
deactivate RPC

== 購読解除 ==

A -> ML : OP_OTHELLO_SUB(19)\n{subscribe: false}
activate ML
ML -> ML : delete OthelloSubs[sidA]
deactivate ML

@enduml
