@startuml
title オセロ対戦シーケンス図
skinparam sequenceMessageAlign center
skinparam maxMessageSize 200

actor "プレイヤーA\n(黒)" as A
actor "プレイヤーB\n(白)" as B
actor "観戦者C" as C
participant "Nakama\n(RPC)" as RPC
participant "MatchLoop\n(SignalHandler)" as ML
database "sync.Map\n(インメモリ)" as MEM

== 購読登録 ==

A -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidA] = true
deactivate ML

B -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidB] = true
deactivate ML

C -> ML : OP_OTHELLO_SUB(19)\n{subscribe: true}
activate ML
ML -> ML : OthelloSubs[sidC] = true
deactivate ML

== ゲーム作成 ==

A -> RPC : othelloCreate\n{worldId: 0}
activate RPC
RPC -> MEM : OthelloGame 作成\nstatus=waiting, turn=1
RPC -> ML : MatchSignal\n"othelloBlocks"\n(外枠36ブロック)
activate ML
ML -> A : OP_BLOCK_UPDATE(4)\n木枠ブロック x36
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC -> ML : MatchSignal\n"othelloBlocks"\n(盤面ブロック)
activate ML
ML -> A : OP_BLOCK_UPDATE(4)\n初期盤面ブロック
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC --> A : OthelloUpdatePayload\n{gameId, status=waiting}
deactivate RPC

== ゲーム一覧 ==

B -> RPC : othelloList\n{worldId: 0}
activate RPC
RPC -> MEM : ゲーム検索\n(未終了 & 同ワールド)
RPC --> B : {games: [{gameId, status=waiting, ...}]}
deactivate RPC

== 対戦参加 ==

B -> RPC : othelloJoin\n{gameId}
activate RPC
RPC -> MEM : white=B, status=playing
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{status=playing, turn=1}
ML -> B : OP_OTHELLO_UPDATE(18)\n{status=playing, turn=1}
ML -> C : OP_OTHELLO_UPDATE(18)\n{status=playing, turn=1}
deactivate ML
RPC --> B : OthelloUpdatePayload\n{status=playing, turn=1}
deactivate RPC

== 着手（黒: プレイヤーA） ==

A -> RPC : othelloMove\n{gameId, row=2, col=3}
activate RPC
RPC -> MEM : 合法手判定 → 裏返し\nturn: 1→2
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{turn=2, lastMove=19}
ML -> B : OP_OTHELLO_UPDATE(18)\n{turn=2, lastMove=19}
ML -> C : OP_OTHELLO_UPDATE(18)\n{turn=2, lastMove=19}
deactivate ML
RPC -> ML : MatchSignal\n"othelloBlocks"\n(差分のみ)
activate ML
ML -> A : OP_BLOCK_UPDATE(4)\n変化マスのブロック
ML -> B : OP_BLOCK_UPDATE(4)\n(AOI内なら)
ML -> C : OP_BLOCK_UPDATE(4)\n(AOI内なら)
deactivate ML
RPC --> A : OthelloUpdatePayload\n{turn=2}
deactivate RPC

== 着手（白: プレイヤーB） ==

B -> RPC : othelloMove\n{gameId, row=2, col=2}
activate RPC
RPC -> MEM : 合法手判定 → 裏返し\nturn: 2→1
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)
ML -> B : OP_OTHELLO_UPDATE(18)
ML -> C : OP_OTHELLO_UPDATE(18)
deactivate ML
RPC -> ML : MatchSignal\n"othelloBlocks"
activate ML
ML -> A : OP_BLOCK_UPDATE(4)
ML -> B : OP_BLOCK_UPDATE(4)
ML -> C : OP_BLOCK_UPDATE(4)
deactivate ML
RPC --> B : OthelloUpdatePayload\n{turn=1}
deactivate RPC

note over A, B : ...（交互に着手を繰り返す）...

== 投了 ==

B -> RPC : othelloResign\n{gameId}
activate RPC
RPC -> MEM : status=finished\nwinner=1 (黒勝ち)
RPC -> ML : MatchSignal\n"othelloUpdate"
activate ML
ML -> A : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> B : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
ML -> C : OP_OTHELLO_UPDATE(18)\n{status=finished, winner=1}
deactivate ML
RPC --> B : OthelloUpdatePayload\n{status=finished, winner=1}
deactivate RPC

== ブロッククリーンアップ（60秒後） ==

RPC -> RPC : goroutine\n60秒 sleep
activate RPC #LightGray
RPC -> MEM : othelloClearBlocks\n10x10 エリアを blockId=0
RPC -> MEM : othelloGames.Delete(gameId)
deactivate RPC

note over A, C : クライアントは次回 syncAOIChunks で\nハッシュ不一致を検出 → ブロック除去

== 購読解除 ==

A -> ML : OP_OTHELLO_SUB(19)\n{subscribe: false}
activate ML
ML -> ML : delete OthelloSubs[sidA]
deactivate ML

@enduml
